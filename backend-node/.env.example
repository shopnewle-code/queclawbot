# QueClaw AI Bot - Environment Variables Template

# ===================================
# SERVER CONFIGURATION
# ===================================
PORT=3000
BASE_URL=https://queclawbot.loca.lt
NODE_ENV=development
DEBUG=false
ALLOWED_ORIGINS=*

# ===================================
# TELEGRAM CONFIGURATION
# ===================================
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_admin_id_here

# ===================================
# PAYPAL CONFIGURATION
# ===================================
# Get these from https://developer.paypal.com/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here
PAYPAL_PLAN_ID=your_paypal_plan_id_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ===================================
# MONGODB CONFIGURATION
# ===================================
MONGO_URI=mongodb://127.0.0.1:27017/queclaw
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/queclaw

# ===================================
# AI ENGINE CONFIGURATION
# ===================================
# Option A: Use your own AI engine service URL
AI_SERVER_URL=http://localhost:8000
AI_PROVIDER=auto

# Option B: Direct OpenAI API fallback (recommended for Railway)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===================================
# RATE LIMITING (optional)
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# LOGGING (optional)
# ===================================
LOG_LEVEL=info
